SECRET_KEY=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
SESSION_COOKIE_SECURE=false
FLASK_DEBUG=0
# Number of trusted reverse proxy hops in front of this app (e.g. 1 if
# nginx terminates TLS and proxies directly to this app). Leave at 0 unless
# you have a reverse proxy that overwrites X-Forwarded-For - otherwise a
# client can spoof this header to bypass login rate limiting.
TRUSTED_PROXY_COUNT=0
